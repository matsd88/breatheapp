    "Inhale for 4, hold for 7, exhale for 8. Activates your parasympathetic nervous system for deep relaxation." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4 Sekunden einatmen, 7 halten, 8 ausatmen. Aktiviert das parasympathische Nervensystem für tiefe Entspannung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inhale for 4, hold for 7, exhale for 8. Activates your parasympathetic nervous system for deep relaxation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inhala por 4, mantén por 7, exhala por 8. Activa tu sistema nervioso parasimpático para una relajación profunda."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspirez pendant 4, retenez pendant 7, expirez pendant 8. Active votre système nerveux parasympathique pour une relaxation profonde."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4 सेकंड श्वास लें, 7 सेकंड रोकें, 8 सेकंड श्वास छोड़ें। गहरी विश्राम के लिए पैरासिम्पेथेटिक तंत्रिका तंत्र को सक्रिय करता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspira per 4, trattieni per 7, espira per 8. Attiva il sistema nervoso parasimpatico per un rilassamento profondo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4秒吸って、7秒止めて、8秒吐く。副交感神経系を活性化し、深いリラクゼーションを促します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4초 들이쉬고, 7초 참고, 8초 내쉬기. 부교감 신경계를 활성화하여 깊은 이완을 촉진합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4 tellen inademen, 7 vasthouden, 8 uitademen. Activeert je parasympathisch zenuwstelsel voor diepe ontspanning."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspire por 4, segure por 7, expire por 8. Ativa o sistema nervoso parassimpático para relaxamento profundo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вдох на 4, задержка на 7, выдох на 8. Активирует парасимпатическую нервную систему для глубокого расслабления."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "吸气4秒，屏息7秒，呼气8秒。激活副交感神经系统实现深度放松。"
          }
        }
      }
    },
    "Inhale, hold, exhale, and hold — each for 4 seconds. Used by Navy SEALs to stay calm under pressure." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einatmen, halten, ausatmen und halten — jeweils 4 Sekunden. Von Navy SEALs verwendet, um unter Druck ruhig zu bleiben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inhale, hold, exhale, and hold — each for 4 seconds. Used by Navy SEALs to stay calm under pressure."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inhala, mantén, exhala y mantén — cada uno por 4 segundos. Usado por los Navy SEALs para mantener la calma bajo presión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspirez, retenez, expirez et retenez — chacun pendant 4 secondes. Utilisé par les Navy SEALs pour rester calme sous pression."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "श्वास लें, रोकें, श्वास छोड़ें और रोकें — प्रत्येक 4 सेकंड। दबाव में शांत रहने के लिए नेवी सील्स द्वारा उपयोग किया जाता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspira, trattieni, espira e trattieni — ognuno per 4 secondi. Usato dai Navy SEAL per restare calmi sotto pressione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "吸って、止めて、吐いて、止めて — 各4秒。プレッシャーの中で冷静さを保つためにネイビーシールズが使用。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "들이쉬고, 참고, 내쉬고, 참기 — 각 4초. 해군 특수부대가 압박 속에서 침착함을 유지하기 위해 사용."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inademen, vasthouden, uitademen en vasthouden — elk 4 seconden. Gebruikt door Navy SEALs om kalm te blijven onder druk."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspire, segure, expire e segure — cada um por 4 segundos. Usado pelos Navy SEALs para manter a calma sob pressão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вдох, задержка, выдох и задержка — по 4 секунды каждый. Используется морскими котиками для сохранения спокойствия под давлением."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "吸气、屏息、呼气、屏息——各4秒。海豹突击队用来在压力下保持冷静。"
          }
        }
      }
    },
