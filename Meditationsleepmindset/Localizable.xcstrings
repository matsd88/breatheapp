    "Breathe in through one nostril, out through the other. Balances left and right brain hemispheres." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch ein Nasenloch einatmen, durch das andere ausatmen. Gleicht linke und rechte Gehirnhälften aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Breathe in through one nostril, out through the other. Balances left and right brain hemispheres."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respira por una fosa nasal y exhala por la otra. Equilibra los hemisferios cerebrales izquierdo y derecho."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspirez par une narine, expirez par l'autre. Équilibre les hémisphères gauche et droit du cerveau."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक नथुने से श्वास लें, दूसरे से छोड़ें। बाएँ और दाएँ मस्तिष्क गोलार्धों को संतुलित करता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspira da una narice, espira dall'altra. Equilibra gli emisferi cerebrali sinistro e destro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "片方の鼻から吸い、もう片方から吐く。左右の脳半球のバランスを整えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한쪽 콧구멍으로 들이쉬고, 다른 쪽으로 내쉬기. 좌뇌와 우뇌의 균형을 맞춥니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adem in door één neusgat, uit door het andere. Balanceert linker- en rechterhersenhelft."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respire por uma narina e expire pela outra. Equilibra os hemisférios cerebrais esquerdo e direito."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вдох через одну ноздрю, выдох через другую. Уравновешивает левое и правое полушария мозга."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
