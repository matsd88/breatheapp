    "30 rapid deep breaths followed by a breath hold. Increases oxygen levels and mental clarity." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 schnelle tiefe Atemzüge gefolgt von einer Atempause. Erhöht den Sauerstoffgehalt und die mentale Klarheit."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 rapid deep breaths followed by a breath hold. Increases oxygen levels and mental clarity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 respiraciones profundas rápidas seguidas de una retención. Aumenta los niveles de oxígeno y la claridad mental."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 respirations profondes rapides suivies d'une rétention. Augmente les niveaux d'oxygène et la clarté mentale."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 तेज़ गहरी सांसें जिसके बाद सांस रोकना। ऑक्सीजन स्तर और मानसिक स्पष्टता बढ़ाता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 respiri profondi rapidi seguiti da un'apnea. Aumenta i livelli di ossigeno e la chiarezza mentale."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30回の速い深呼吸の後に息を止める。酸素レベルと思考の明晰さを高めます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30회의 빠른 깊은 호흡 후 숨 참기. 산소 수준과 정신적 명료함을 높입니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 snelle diepe ademhalingen gevolgd door adem vasthouden. Verhoogt zuurstofniveaus en mentale helderheid."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 respirações profundas rápidas seguidas de uma retenção. Aumenta os níveis de oxigênio e a clareza mental."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30 быстрых глубоких вдохов с последующей задержкой дыхания. Повышает уровень кислорода и ясность ума."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "30次快速深呼吸后屏息。提高氧气水平和思维清晰度。"
          }
        }
      }
    },
