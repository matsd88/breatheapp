    "Short, powerful exhales with passive inhales. Clears the mind and boosts energy quickly." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kurze, kräftige Ausatmungen mit passiven Einatmungen. Klärt den Geist und steigert die Energie schnell."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Short, powerful exhales with passive inhales. Clears the mind and boosts energy quickly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exhalaciones cortas y poderosas con inhalaciones pasivas. Aclara la mente y aumenta la energía rápidamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expirations courtes et puissantes avec inspirations passives. Clarifie l'esprit et booste l'énergie rapidement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "छोटी, शक्तिशाली श्वास छोड़ना और निष्क्रिय श्वास लेना। मन को साफ़ करता है और जल्दी ऊर्जा बढ़ाता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Espirazioni brevi e potenti con inspirazioni passive. Schiarisce la mente e aumenta l'energia rapidamente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "短く力強い呼気と受動的な吸気。素早く頭をクリアにし、エネルギーを高めます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "짧고 강한 내쉬기와 자연스러운 들이쉬기. 빠르게 마음을 맑게 하고 에너지를 높입니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Korte, krachtige uitademingen met passieve inademingen. Maakt het hoofd helder en geeft snel energie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Expirações curtas e poderosas com inspirações passivas. Clareia a mente e aumenta a energia rapidamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Короткие мощные выдохи с пассивными вдохами. Быстро очищает ум и повышает энергию."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "短促有力的呼气配合被动吸气。快速清理头脑，提升能量。"
          }
        }
      }
    },
